# Frontend (Vite)
# Dev: omit VITE_API_URL to use Vite’s proxy → POST /api/enquiries → http://localhost:3001
# Production: set to your real API base (must include /api if your routes live under /api), e.g.
#   VITE_API_URL=https://api.rathansdrivingschool.co.uk/api
# If unset in production builds, the app will NOT call /api (avoids 404 on static hosting) and will
# use the FormSubmit email fallback instead.
# VITE_API_URL=http://localhost:3001/api

# Contact form: when /api/enquiries is unavailable (typical on static hosting), submissions
# fall back to FormSubmit (emails CONTACT_EMAIL from site.ts). First submission triggers
# FormSubmit’s one-time email confirmation. Set to false to disable that fallback.
# VITE_FORMSUBMIT_FALLBACK=false

# WhatsApp: use full number with country code, no + or spaces (e.g. 447700900000)
# Replace with your real business number for production
